# Resend API key — required for /api/contact to deliver mail.
# Create at https://resend.com/api-keys after verifying frontrunner.io as a sending domain.
RESEND_API_KEY=

# Optional overrides. Defaults are used if unset.
# CONTACT_TO_EMAIL=info@frontrunner.io
# CONTACT_FROM_EMAIL="Kontaktformular <kontakt@send.frontrunner.io>"
