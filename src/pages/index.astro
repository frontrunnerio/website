---
import Layout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'AstroWind — Free template for creating websites with Astro + Tailwind CSS',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  
  <Hero2
    tagline=""
    title="Ship faster.<br> Stay secure. Automate everything."
    subtitle="Wir helfen Unternehmen, ihre Software schneller und sicherer auszuliefern — durch DevSecOps, Automatisierung und klare Prozesse."
    actions={[
      {
        variant: 'primary',
        text: 'Kostenlos anfragen',
        href: 'mailto:andreas.boehrnsen@frontrunner.io',
        target: '_blank'
      },
      { text: 'Mehr erfahren', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'Frontrunner IO Hero Image' }}
  />

  <!--
  <Hero
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'Frontrunner IO Hero Image' }}
    actions={[
      {
        variant: 'primary',
        text: 'Kostenlos anfragen',
        href: 'mailto:andreas.boehrnsen@frontrunner.io',
        target: '_blank'
      },
      { text: 'Mehr erfahren', href: '#features' },
    ]}
  >
    <Fragment slot="title">
      Ship faster. Stay secure. <span class="hidden xl:inline">Automate everything.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Wir helfen Unternehmen, ihre Software schneller und sicherer auszuliefern — durch DevSecOps, Automatisierung und klare Prozesse.
    </Fragment>
  </Hero>
 -->

  <!-- Note Widget ******************* -->

  <Note title="Philosophie:" description="Simplicity, Best Practices and High Performance" />

  <!-- Features Widget - Problem statement *************** -->
  
  <Features
    id="problem-statement"
    tagline="The reality in many organizations"
    title="Software delivery is slower, riskier, and more complex than it should be"
    subtitle="Zwischen steigenden Sicherheitsanforderungen, wachsender Tool-Landschaft und manuellem Aufwand verlieren viele Teams Geschwindigkeit — und Kontrolle. Was eigentlich Innovation ermöglichen sollte, wird zum Bottleneck."
    items={[
      {
        title: 'Manual processes slow everything down',
        description:
          'Release-Prozesse hängen von manuellen Schritten ab — fehleranfällig, langsam und schwer skalierbar.',
        icon: 'tabler:hourglass-high',
      },
      {
        title: 'Tool sprawl instead of a platform',
        description:
          'Zu viele Tools ohne klare Integration führen zu Medienbrüchen, ineffizienten Workflows und unnötiger Komplexität.',
        icon: 'tabler:apps',
      },
      {
        title: 'Security comes too late',
        description:
          'Security wird oft erst am Ende berücksichtigt — was Releases verzögert und Risiken erhöht.',
        icon: 'tabler:shield-half',
      },
      {
        title: 'Slow and risky releases',
        description:
          'Deployments dauern zu lange oder sind mit Unsicherheit verbunden — Innovation wird ausgebremst.',
        icon: 'tabler:alert-triangle',
      },
      {
        title: 'Compliance creates friction',
        description:
          "Regulatorische Anforderungen wie DORA oder ISO führen zu zusätzlichem Aufwand statt zu Klarheit.",
        icon: 'tabler:scale',
      },
      {
        title: 'Lack of transparency and traceability',
        description:
          "Es fehlt an klarer Nachvollziehbarkeit — besonders kritisch für Audits und regulierte Branchen.",
        icon: 'tabler:route-x',
      },
    ]}
  />

  <!-- Content Widget **************** -->
  
  <Content
    isReversed
    tagline="Wir bieten"
    title="Unsere Leistungen"
    items={[
      {
        title: 'Analyse eurer aktuellen Software-Delivery',
        description:
          'Ganzheitliche Betrachtung eurer Pipeline von Code bis Deployment — inkl. Prozesse, Tools und Verantwortlichkeiten.',
      },
      {
        title: 'Identifikation von Risiken und Bottlenecks',
        description:
          'Aufdecken von Sicherheitslücken, manuellen Engpässen und ineffizienten Abläufen, die euch ausbremsen.',
      },
      {
        title: 'Konkrete Handlungsempfehlungen',
        description:
          'Keine Theorie: ihr erhaltet klare, priorisierte Maßnahmen, die sofort umsetzbar sind.',
      },
      {
        title: 'Ergebnis: klare Roadmap in wenigen Tagen',
        description:
          'Eine strukturierte, realistische Roadmap als Grundlage für schnelle Verbesserungen und fundierte Entscheidungen.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Colorful Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">DevSecOps Assessment</h3>
      Der schnellste Weg zu Klarheit
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Aufbau oder Optimierung von GitLab',
        description:
          'Einrichtung oder Weiterentwicklung eurer GitLab-Instanz als zentrale Plattform für Development, Security und Operations.',
      },
      {
        title: 'CI/CD Pipelines (inkl. Security Scans)',
        description:
          'Aufbau performanter, automatisierter Pipelines mit integrierten Sicherheitsprüfungen.',
      },
      {
        title: 'Rechte- und Rollenmodelle (Compliance-ready)',
        description:
          'Klare Zugriffskonzepte für Teams und Audits — nachvollziehbar und sicher.',
      },
      {
        title: 'Infrastructure as Code Integration',
        description:
          'Einbindung eurer Infrastruktur in den Delivery-Prozess für reproduzierbare und versionierte Deployments.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Blueprint Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">GitLab Implementation & Optimization</h3>
      Alles in einer Plattform
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: 'Migration von Jenkins, Azure DevOps, GitHub etc. zu GitLab',
        description:
          'Strukturierte Überführung bestehender Systeme in eine konsolidierte Plattform — ohne Betriebsunterbrechung.',
      },
      {
        title: 'Konsolidierung von Toolchains',
        description:
          'Reduktion von Komplexität durch Zusammenführung von Tools und Prozessen.',
      },
      {
        title: 'Minimierung von Betriebsaufwand',
        description:
          'Weniger Wartung, weniger Schnittstellen, weniger Fehlerquellen.',
      },
      {
        title: 'Sicherstellung von Compliance',
        description:
          'Migration unter Berücksichtigung regulatorischer Anforderungen und Auditierbarkeit.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611462985358-60d3498e0364?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Astronauts Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Migration &amp; Konsolidierung</h3>
      Raus aus dem Tool-Chaos
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Hands-on Unterstützung im Team',
        description:
          'Direkte Mitarbeit in euren Projekten, um Ergebnisse schnell und pragmatisch umzusetzen.',
      },
      {
        title: 'Coaching für Entwickler & Plattform-Teams',
        description:
          'Vermittlung von Best Practices, damit eure Teams eigenständig weiterarbeiten können.',
      },
      {
        title: 'Aufbau von DevSecOps Mindset',
        description:
          'Förderung einer Kultur, in der Sicherheit und Geschwindigkeit zusammen gedacht werden.',
      },
      {
        title: 'Nachhaltige Transformation',
        description:
          'Fokus auf langfristige Verbesserung statt kurzfristiger Optimierung.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1531030874896-fdef6826f2f7?q=80&w=1740&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D',
      alt: 'Gitlab Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Begleitung &amp; Coaching
      </h3>
      Nicht nur Konzepte — echte Umsetzung
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>
  

  Alle Leistungen sind modular kombinierbar — vom schnellen Assessment bis zur vollständigen Transformation.
  
  <!-- Steps Widget ****************** -->
  
  <Steps
    title="Wie wir arbeiten"
    items={[
      {
        title: 'Schritt 1: <span class="font-medium">Assessment</span>',
        description:
          "Wir analysieren eure aktuelle Situation.",
        icon: 'tabler:search',
      },
      {
        title: 'Schritt 2: <span class="font-medium">Roadmap</span>',
        description:
          "Wir erstellen eine klare, priorisierte Maßnahmenliste.",
        icon: 'tabler:route',
      },
      {
        title: 'Schritt 3: <span class="font-medium">Implementation</span>',
        description:
          'Auf Wunsch implementieren wir die Maßnahmen mit eurem Team.',
        icon: 'tabler:tools',
      },
      {
        title: 'Schritt 4: <span class="font-medium">Enablement</span>',
        description:
          'Wir transferieren das Wissen und ermöglichen euch, die Maßnahmen kontinuierlich zu verbessern.',
        icon: 'tabler:school',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  />

